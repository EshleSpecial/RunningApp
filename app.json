{
  "expo": {
    "name": "I Can Do Hard Things",
    "slug": "icdht",
    "version": "1.0.0",
    "scheme": "icdht",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1a2f5a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.icdht.app",
      "deploymentTarget": "15.1",
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "package": "com.icdht.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a2f5a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow RunDisney Training to add workouts to your calendar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
