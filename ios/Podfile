require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'RunDisneyTraining' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )
    # Patch fmt headers to disable consteval (incompatible with this Clang version)
    Dir.glob("#{installer.sandbox.root}/fmt/include/fmt/*.h").each do |header|
      next unless File.writable?(header)
      content = File.read(header)
      patched = content.gsub(/^(#\s*define\s+FMT_USE_CONSTEVAL)\s+1/, '\1 0')
      File.write(header, patched) if patched != content
    end

    # Patch folly headers that conditionally include folly/coro/Coroutine.h —
    # disable the FOLLY_HAS_COROUTINES block directly in the source.
    %w[Expected.h Optional.h].each do |fname|
      `find #{installer.sandbox.root} -name '#{fname}' -path '*/folly/*' 2>/dev/null`.split("\n").each do |path|
        real = File.symlink?(path) ? (File.realpath(path) rescue path) : path
        [path, real].uniq.each do |f|
          next unless File.exist?(f)
          File.chmod(0644, f) rescue nil
          content = File.read(f) rescue nil
          next unless content
          patched = content.gsub(/#if\s+FOLLY_HAS_COROUTINES/, '#if 0 // patched: FOLLY_HAS_COROUTINES')
          File.write(f, patched) if patched != content
        end
      end
    end

    # Disable folly coroutines via compiler flag so Expected.h's #if FOLLY_HAS_COROUTINES
    # block is never entered and the missing folly/coro/Coroutine.h is never included.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        flags = config.build_settings['OTHER_CPLUSPLUSFLAGS']
        case flags
        when nil, ''
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -DFOLLY_HAS_COROUTINES=0'
        when String
          unless flags.include?('-DFOLLY_HAS_COROUTINES=0')
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags + ' -DFOLLY_HAS_COROUTINES=0'
          end
        when Array
          unless flags.include?('-DFOLLY_HAS_COROUTINES=0')
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags + ['-DFOLLY_HAS_COROUTINES=0']
          end
        end
      end
    end
    # Also write the flag into the main project xcconfig as a fallback
    installer.generated_projects.each do |project|
      project.targets.each do |target|
        target.build_configurations.each do |config|
          flags = config.build_settings['OTHER_CPLUSPLUSFLAGS']
          case flags
          when nil, ''
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -DFOLLY_HAS_COROUTINES=0'
          when String
            unless flags.include?('-DFOLLY_HAS_COROUTINES=0')
              config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags + ' -DFOLLY_HAS_COROUTINES=0'
            end
          when Array
            unless flags.include?('-DFOLLY_HAS_COROUTINES=0')
              config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags + ['-DFOLLY_HAS_COROUTINES=0']
            end
          end
        end
      end
      project.save
    end

    # Suppress -Woverloaded-virtual in RNReanimated (non-virtual override hides virtual)
    installer.pods_project.targets.each do |target|
      next unless target.name == 'RNReanimated'
      target.build_configurations.each do |config|
        flags = config.build_settings['OTHER_CPLUSPLUSFLAGS']
        case flags
        when nil, ''
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -Wno-overloaded-virtual'
        when String
          unless flags.include?('-Wno-overloaded-virtual')
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags + ' -Wno-overloaded-virtual'
          end
        when Array
          unless flags.include?('-Wno-overloaded-virtual')
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags + ['-Wno-overloaded-virtual']
          end
        end
      end
    end

    # Patch ReanimatedMountHook.h: fix 'UIManagerMountHookf' typo and non-virtual override
    reanimated_hook_candidates = [
      "#{installer.sandbox.root}/Headers/Private/RNReanimated/reanimated/Fabric/ReanimatedMountHook.h",
    ] + `find #{installer.sandbox.root} -name 'ReanimatedMountHook.h' 2>/dev/null`.split("\n")
    reanimated_hook_candidates.uniq.each do |path|
      real = File.symlink?(path) ? (File.realpath(path) rescue path) : path
      [path, real].uniq.each do |f|
        next unless File.exist?(f)
        File.chmod(0644, f) rescue nil
        content = File.read(f) rescue nil
        next unless content
        patched = content
          .gsub('UIManagerMountHookf', 'UIManagerMountHook')
          .gsub('double mountTime) noexcept override', 'HighResTimeStamp mountTime) noexcept override')
          .gsub('double mountTime) noexcept', 'HighResTimeStamp mountTime) noexcept')
        File.write(f, patched) if patched != content
      end
    end

    # Also patch ReanimatedMountHook.cpp for the same signature change
    `find #{installer.sandbox.root} -name 'ReanimatedMountHook.cpp' 2>/dev/null`.split("\n").each do |path|
      real = File.symlink?(path) ? (File.realpath(path) rescue path) : path
      [path, real].uniq.each do |f|
        next unless File.exist?(f)
        File.chmod(0644, f) rescue nil
        content = File.read(f) rescue nil
        next unless content
        patched = content
          .gsub('double mountTime)', 'HighResTimeStamp mountTime)')
          .gsub('double) noexcept', 'HighResTimeStamp) noexcept')
        File.write(f, patched) if patched != content
      end
    end
    # Also patch the source in node_modules
    rnh_src = File.join(File.dirname(installer.sandbox.root), '../node_modules/react-native-reanimated/Common/cpp/reanimated/Fabric/ReanimatedMountHook.h')
    rnh_cpp = File.join(File.dirname(installer.sandbox.root), '../node_modules/react-native-reanimated/Common/cpp/reanimated/Fabric/ReanimatedMountHook.cpp')
    [rnh_src, rnh_cpp].each do |f|
      next unless File.exist?(f)
      content = File.read(f)
      patched = content
        .gsub('UIManagerMountHookf', 'UIManagerMountHook')
        .gsub('double mountTime)', 'HighResTimeStamp mountTime)')
        .gsub('double) noexcept', 'HighResTimeStamp) noexcept')
      File.write(f, patched) if patched != content
    end

    # Patch reanimated LayoutAnimations: parentShadowView removed from ShadowViewMutation
    reanimated_la_dir = File.join(File.dirname(installer.sandbox.root), '../node_modules/react-native-reanimated/Common/cpp/reanimated/LayoutAnimations')
    helper_fn = <<~CPP

      static inline facebook::react::ShadowView reanimated_parentShadowViewStub(facebook::react::Tag tag) {
        facebook::react::ShadowView sv{};
        sv.tag = tag;
        return sv;
      }
    CPP
    [
      File.join(reanimated_la_dir, 'LayoutAnimationsUtils.cpp'),
      File.join(reanimated_la_dir, 'LayoutAnimationsProxy.cpp'),
    ].each do |f|
      next unless File.exist?(f)
      content = File.read(f)
      patched = content
        .gsub('mutation.parentShadowView.layoutMetrics.frame.size.width', '0')
        .gsub('mutation.parentShadowView.layoutMetrics.frame.size.height', '0')
        .gsub('mutation.parentShadowView.tag', 'mutation.parentTag')
        .gsub(/\b(InsertMutation|RemoveMutation)\(mutation\.parentShadowView,/, '\1(mutation.parentTag,')
        .gsub('mutation.newChildShadowView, *newView, mutation.parentShadowView)', 'mutation.newChildShadowView, *newView, mutation.parentTag)')
        .gsub('std::make_shared<ShadowView>(mutation.parentShadowView)',
              'std::make_shared<ShadowView>(reanimated_parentShadowViewStub(mutation.parentTag))')
        .gsub('mutation.parentShadowView',
              'reanimated_parentShadowViewStub(mutation.parentTag)')
      if patched != content
        unless patched.include?('reanimated_parentShadowViewStub(facebook::react::Tag')
          last_include = patched.rindex(/#include\s+[<"]/)
          if last_include
            eol = patched.index("\n", last_include)
            patched = patched[0..eol] + helper_fn + patched[(eol+1)..]
          end
        end
        File.write(f, patched)
      end
    end

    # Patch NativeReanimatedModule.cpp: add shadowNodeFromValue shim (renamed in RN 0.81)
    nrm = File.join(File.dirname(installer.sandbox.root), '../node_modules/react-native-reanimated/Common/cpp/reanimated/NativeModules/NativeReanimatedModule.cpp')
    if File.exist?(nrm)
      content = File.read(nrm)
      shim = <<~CPP

        // RN 0.81 compat: shadowNodeFromValue was replaced by shadowNodeListFromValue
        static inline facebook::react::ShadowNode::Shared shadowNodeFromValue(
            jsi::Runtime &rt, const jsi::Value &value) {
          auto list = facebook::react::shadowNodeListFromValue(rt, value);
          if (list && !list->empty()) return list->at(0);
          return nullptr;
        }
      CPP
      unless content.include?('shadowNodeFromValue was replaced')
        insert_after = '#ifdef RCT_NEW_ARCH_ENABLED'
        idx = content.index(insert_after)
        if idx
          eol = content.index("\n", idx)
          content = content[0..eol] + shim + content[(eol+1)..]
          File.write(nrm, content)
        end
      end
    end

    # Patch WorkletRuntimeDecorator.cpp: rename parseArgs → AsyncQueue (corrupted install)
    wrd = File.join(File.dirname(installer.sandbox.root), '../node_modules/react-native-reanimated/Common/cpp/worklets/WorkletRuntime/WorkletRuntimeDecorator.cpp')
    if File.exist?(wrd)
      content = File.read(wrd)
      patched = content.gsub('parseArgs(', 'AsyncQueue(')
      File.write(wrd, patched) if patched != content
    end

    # Patch react-native-screens to remove reference to removed parentShadowView field
    rnscreens_file = "#{installer.sandbox.root}/RNScreens/RNSScreenRemovalListener.cpp"
    if File.exist?(rnscreens_file)
      content = File.read(rnscreens_file)
      patched = content.gsub(
        /strcmp\(mutation\.parentShadowView\.componentName,\s*"RNSScreenStack"\)\s*==\s*0/,
        'true'
      )
      File.write(rnscreens_file, patched) if patched != content
    end
  end
end
